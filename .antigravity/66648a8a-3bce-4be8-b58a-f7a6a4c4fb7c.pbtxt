                 <button key={size} onClick={() => setImageSize(size)} className={`flex-1 py-2 text-sm font-bold rounded-md transition-all ${imageSize === size ? \'bg-white text-blue-600 shadow-sm\' : \'text-gray-500 hover:text-gray-700\'}`}>{size}</button>                        ))}                    </div>                  </div>                </div>                {/* Generate Button */}                <div className=\"mt-10 pt-6 border-t\">                  <button                    onClick={handleSubmit}                    disabled={!isFormValid || isGeneratingAds}                    className=\"w-full flex items-center justify-center bg-gradient-to-r from-[#4285F4] to-[#34A853] text-white font-bold py-4 px-6 rounded-lg hover:from-[#3367D6] hover:to-[#2c9f67] disabled:bg-gray-300 disabled:cursor-not-allowed transition-all shadow-lg transform hover:scale-[1.02]\"                  >                    {isGeneratingAds ? \'Blending...\' : \'Blend me some ads!\'}                  </button>                </div>              </div>            </div>          </div>          {/* Right Panel: Results */}"
