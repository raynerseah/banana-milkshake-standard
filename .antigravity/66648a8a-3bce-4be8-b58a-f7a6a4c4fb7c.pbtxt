    tool_config {
      code {
        disable_extensions: ".ipynb"
        apply_edits: true
        replace_content_tool_config {
          max_fuzzy_edit_distance_fraction: 0.001
          allow_partial_replacement_success: true
          fast_apply_fallback_config {
            enabled: true
            prompt_unchanged_threshold: 5
            content_view_radius_lines: 200
            content_edit_radius_lines: 5
            fast_apply_model: MODEL_GOOGLE_GEMINI_2_5_FLASH
          }
          show_triggered_memories: true
          disable_allow_multiple: false
          use_line_range: true
        }
        auto_fix_lints_config {
          enabled: false
          notifying_prompt: "As IDE feedback, the following lint errors may be related to your recent edits up to this point. Consider whether they deserve immediate attention. If worth addressing, clearly comment on them and/or fix them. Be explicit in acknowledging lints and explaining your fix\'s approach. AVOID unproductive loops; if you detect yourself repeatedly creating/fixing lints in a short period, offer some thoughts but MOVE ON."
        }
        allow_edit_gitignore: false
        use_replace_content_propose_code: false
        classify_edit: false
        skip_await_lint_errors: false
        provide_importance: false
        use_sed_edit: false
      }
      intent {
        intent_model: MODEL_GOOGLE_GEMINI_2_5_FLASH
        max_context_tokens: 40000
      }
      grep {
        max_grep_results: 50
        use_code_search: false
        disable_fallback_to_local_execution: false
      }
      find {
        max_find_results: 50
        use_code_search: false
        disable_fallback_to_local_execution: false
        force_disable: true
      }
      run_command {
        max_chars_command_stdout: 8192
        force_disable: false
        auto_command_config {
          auto_execution_policy: CASCADE_COMMANDS_AUTO_EXECUTION_EAGER
        }
        enable_ide_terminal_execution: false
        shell_name: "bash"
        shell_path: "bash"
        forbid_search_commands: false
        force_go_terminal_execution: false
        enable_pty: false
        enable_persistent_mode: false
      }
      view_file {
        allow_view_gitignore: false
        split_outline_tool: true
        max_total_outline_bytes: 8192
        show_full_file_bytes: 8192
        max_bytes_per_outline_item: 512
        show_triggered_memories: true
        max_lines_per_view: 800
        include_line_numbers: true
      }
      suggested_response {
        force_disable: true
      }
      search_web {
        force_disable: false
        third_party_config {
          provider: THIRD_PARTY_WEB_SEARCH_PROVIDER_GEMINI
        }
      }
      mcp {
        force_disable: false
        max_output_bytes: 4096
      }
      list_dir {
      }
      command_status {
        use_delta: true
        max_output_characters: 8192
        min_output_characters: 1024
        max_wait_duration_seconds: 300
        output_stabilization_duration_seconds: 5
        enable_input_detection: true
        input_detection_model: MODEL_GOOGLE_GEMINI_2_5_FLASH_LITE
      }
      antigravity_browser {
        enabled: false
        capture_browser_screenshot {
          enable_saving: true
        }
        browser_subagent {
          mode: BROWSER_SUBAGENT_MODE_SUBAGENT_ONLY
          browser_subagent_model: MODEL_PLACEHOLDER_M18
          use_detailed_converter: true
          disable_onboarding: false
          subagent_reminder_mode {
            verify_screenshots {
            }
          }
          max_context_tokens: 67420
          context_config {
            type: CONTEXT_TYPE_WITH_MARKDOWN_TRAJECTORY_SUMMARY
            max_chars: 10000
          }
          dom_extraction_config {
            include_coordinates: true
          }
          low_level_tools_config {
            enable_low_level_tools_instructions: true
            enable_mouse_tools: true
          }
          enable_scratchpad: true
        }
        click_browser_pixel {
          click_feedback {
            display_color: "red"
            red: 255
            green: 0
            blue: 0
            alpha: 255
            radius: 25
            enabled: true
            feedback_type: FEEDBACK_TYPE_MOUSE_POINTER
          }
        }
        tool_set_mode: BROWSER_TOOL_SET_MODE_ALL_INPUT_PIXEL_OUTPUT
        disable_open_url: false
        browser_state_diffing_config {
          capture_agent_action_diffs: true
          include_dom_tree_in_diffs: false
        }
        variable_wait_tool: true
        dom_extraction_config {
          include_coordinates: true
        }
        disable_workspace_api: false
        browser_list_network_requests_tool_config {
          enabled: true
        }
        browser_get_network_request_tool_config {
          enabled: true
        }
        use_antigravity_as_browser_prompting: false
        enable_refresh_tool: false
        disable_read_browser_page: false
        use_extended_timeout: false
        log_timeout_errors_instead_of_sentry: false
        skip_permission_checks: false
        display_on_crd: true
        generate_recording_synchronously: false
        enable_browser_subagent_v2: false
      }
      code_search {
        force_disable: false
      }
      internal_search {
        max_results: 10
        max_content_length: 5000
      }
      notify_user {
        artifact_review_mode: ARTIFACT_REVIEW_MODE_ALWAYS
      }
      finish {
      }
      notebook_edit {
        enabled: false
      }
      invoke_subagent {
        enabled: false
        max_nesting_depth: 10
        allow_task_mode: false
        always_inherit_model: true
      }
      generate_image {
        output_directory: "/src/assets/images"
      }
      permission_config {
        enterprise_config {
          enforce_workspace_validation: true
        }
        effective_grants {
        }
      }
      auto_allow_all_interactions: false
    }
    ephemeral_messages_config {
      enabled: false
      persistence_level: EPHEMERAL_MESSAGE_PERSISTENCE_LEVEL_LATEST_ONLY
      browser_ephemeral_options: BROWSER_EPHEMERAL_OPTION_SCREENSHOT
      browser_ephemeral_options: BROWSER_EPHEMERAL_OPTION_DOM
      use_allowlist: true
    }
    google {
      planner_mode: CONVERSATIONAL_PLANNER_MODE_DEFAULT
      eval_mode: false
      agentic_mode: false
    }
    custom_model_info_override {
      model_name: "gemini-3.1-pro-preview"
      thinking_level: 3
    }
    retry_config {
      model_output_retry {
        max_retries: 4
        forbid_tool_use: true
      }
      api_retry {
        max_retries: 2
        initial_sleep_duration_ms: 1000
        exponential_multiplier: 2.0
        include_error_feedback: true
        range: 0.4
      }
    }
    knowledge_config {
      enabled: false
      model: MODEL_PLACEHOLDER_M18
      max_context_tokens: 200000
      max_invocations: 20
      min_turns_between_knowledge_generation: 10000
      max_knowledge_items: 20
      max_artifacts_per_ki: 20
      max_title_length: 100
      max_summary_length: 1000
    }
    no_tool_summary: false
    no_wait_for_previous_tools: false
    disable_loop_detection: false
  }
  execution_id: "1aedc0f6-0c61-4d9b-84c3-ee2b42d57c72"
