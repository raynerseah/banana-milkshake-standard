    generator_model: MODEL_GOOGLE_GEMINI_INTERNAL_BYOM
    execution_id: "1aedc0f6-0c61-4d9b-84c3-ee2b42d57c72"
    source_trajectory_step_info {
      trajectory_id: "14a16b9e-7c53-44d8-8b6a-17dd3cc94c22"
